// ============================================================================
// Frontend CI pipeline  (lives WITH the code it builds — pipeline-as-code)
//
// Flow:  checkout -> install/build -> SonarQube -> docker build -> Trivy
//        -> push immutable image -> bump tag in the GitOps repo (mern_cicd)
//
// The image is environment-agnostic (backend URL is injected at runtime), so
// the same tag is what gets promoted dev -> prod through Argo CD.
// ============================================================================
pipeline {
    agent any

    environment {
        AWS_REGION      = "ap-south-1"
        REGISTRY        = "637423622313.dkr.ecr.ap-south-1.amazonaws.com"
        IMAGE           = "637423622313.dkr.ecr.ap-south-1.amazonaws.com/mern-frontend"
        IMAGE_TAG       = "${env.BUILD_NUMBER}"

        GITOPS_REPO     = "github.com/devopscalendar101/mern_cicd.git"
        GITOPS_BRANCH   = "main"
        GITOPS_VALUES   = "environments/dev/frontend.yaml"

        SONAR_HOST_URL  = "http://65.0.129.172:9000"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install & Build') {
            steps {
                sh '''
                    npm install
                    npm run build
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonar-frontend', variable: 'SONAR_TOKEN')]) {
                    sh "sonar-scanner -Dsonar.host.url=${SONAR_HOST_URL} -Dsonar.login=${SONAR_TOKEN}"
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    image = docker.build("${IMAGE}:${IMAGE_TAG}", "--no-cache .")
                }
            }
        }

        stage('Trivy Scan') {
            steps {
                sh "trivy image --severity LOW,MEDIUM,HIGH --exit-code 0 --format table ${IMAGE}:${IMAGE_TAG}"
                sh "trivy image --severity CRITICAL --exit-code 1 --format table ${IMAGE}:${IMAGE_TAG}"
            }
        }

        stage('Push Image') {
            steps {
                sh '''
                    aws ecr get-login-password --region ${AWS_REGION} \
                      | docker login --username AWS --password-stdin ${REGISTRY}
                    docker push ${IMAGE}:${IMAGE_TAG}
                '''
            }
        }

        stage('Promote to dev (GitOps)') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'github',
                                 usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                    sh '''
                        set -e
                        rm -rf gitops && git clone https://${GIT_USER}:${GIT_TOKEN}@${GITOPS_REPO} gitops
                        cd gitops
                        git checkout ${GITOPS_BRANCH}

                        TAG=${IMAGE_TAG} yq -i '.image.tag = strenv(TAG)' ${GITOPS_VALUES}

                        git config user.email "ci@devopscalendar101"
                        git config user.name  "jenkins-ci"
                        git add ${GITOPS_VALUES}
                        git commit -m "ci(frontend): deploy ${IMAGE}:${IMAGE_TAG} to dev" || echo "no change"
                        git push origin ${GITOPS_BRANCH}
                    '''
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${IMAGE}:${IMAGE_TAG} || true"
            cleanWs()
        }
    }
}
